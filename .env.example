# ============================================================
# AI-WORKSPACE AGENT CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values

# --- LLM Provider (OpenAI-compatible) ---
# Supports: OpenAI, Anthropic (via proxy), Ollama, LM Studio, etc.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# --- NVD (National Vulnerability Database) API Key ---
# Get free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your-nvd-key-here

# --- Evolution Schedule ---
# Cron expression: default = daily at midnight
EVOLUTION_CRON=0 0 * * *

# --- Dashboard ---
DASHBOARD_PORT=3000

# --- Agent Settings ---
SCAN_DEPTH=10
MAX_FILE_SIZE_MB=5
REPORT_FORMAT=markdown
LOG_LEVEL=info
